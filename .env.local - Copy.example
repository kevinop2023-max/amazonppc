# ============================================================
# Amazon PPC Analytics Platform - Environment Variables
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_SERVICE_ROLE_KEY

# ── Amazon LWA (Login with Amazon) OAuth ──────────────────────
# Get these from: https://developer.amazon.com/loginwithamazon/console/site/lwa/overview.html
# → Create a new Security Profile for "Amazon Advertising API"
# → Add allowed return URL: http://localhost:3000/api/auth/amazon/callback (dev)
# →                        https://yourdomain.com/api/auth/amazon/callback (prod)

AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client.YOUR_CLIENT_ID
AMAZON_LWA_CLIENT_SECRET=YOUR_CLIENT_SECRET
AMAZON_REDIRECT_URI=http://localhost:3000/api/auth/amazon/callback

# ── Token Encryption Key ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)

TOKEN_ENCRYPTION_KEY=YOUR_64_CHAR_HEX_STRING_HERE

# ── App ───────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
